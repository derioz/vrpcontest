rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email.lower() == email.lower();
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data;
    }
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    function isSuperAdmin() {
      return (isAuthenticated() && request.auth.token.email.lower() == 'tx.davidj@gmail.com')
             || hasRole('superadmin')
             || hasRole('owner');
    }
    function isAdmin() {
      return isSuperAdmin() || hasRole('admin');
    }
    function isEditor() {
      return isAdmin() || hasRole('editor');
    }
    // Contest app admin — matches client-side admin check.
    // Checks Firebase Auth UID, Discord provider UID, and email/password users.
    // Does NOT call getUserData()/isAdmin() to avoid errors for Discord users without an email.
    function isContestAdmin() {
      return isAuthenticated()
             && (
                 // Email/password users are always admin in the contest app
                 request.auth.token.firebase.sign_in_provider == 'password'
                 // Check admins collection by Firebase Auth UID
                 || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
                 // Check admins collection by Discord provider UID
                 || ('oidc.discord' in request.auth.token.firebase.identities
                     && exists(/databases/$(database)/documents/admins/$(request.auth.token.firebase.identities['oidc.discord'][0])))
             );
    }

    // --- Collection Rules (Main Website) ---
    match /users/{email} {
      allow get: if isOwner(email) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(email) && request.resource.data.role == 'user';
      allow update: if isOwner(email) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow write: if isAdmin();
    }
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isEditor();
    }
    match /staff/{staffId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- VITAL CONTEST APP RULES ---

    // Admins collection — any authenticated user can read (just checks if their UID doc exists).
    // No sensitive data here; write is console-only.
    match /admins/{discordId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Contest metadata — any authenticated user can write (admin gate enforced client-side)
    match /contests/{contestId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Global settings — any authenticated user can write (admin gate enforced client-side)
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Secrets collection — only contest admins can read or write (e.g., storing private keys securely)
    match /secrets/{doc} {
      allow read, write: if isContestAdmin();
    }

    // Categories — any authenticated user can write (admin gate enforced client-side)
    match /categories/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Photos — authenticated users can create & update (for votes);
    // only the uploader or a contest admin can delete.
    // isContestAdmin() is checked FIRST to avoid isAdmin() throwing for Discord users.
    match /photos/{doc} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isContestAdmin() || (isAuthenticated() && resource.data.uploader_uid == request.auth.uid);
    }

    // Votes — any authenticated user
    match /votes/{doc} {
      allow read, write: if isAuthenticated();
    }

    // Archive: winners saved at end of contest — public read, any authenticated write
    // (only admins can trigger the archive UI, so this is safe)
    match /archived_winners/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // User stats: lifetime cumulative counts — authenticated read/write
    match /user_stats/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
